# Copy to .env and fill secrets locally. Do not commit .env.
# In production, source these from a vault — see docs/secrets.md.

# ── Application ──────────────────────────────────────────
APP_NAME=Regulatory Watch
APP_ENV=dev                   # dev | staging | prod
DEBUG=false
LOG_FORMAT=console            # 'console' for dev, 'json' for prod
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://regwatch:regwatch_secret@db:5432/regwatch
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# DEV-ONLY escape hatch for SQLModel.metadata.create_all() at API
# startup. MUST be false in any non-dev environment — Alembic owns
# the schema. Leaving this true in prod risks DuplicateTable races.
DEV_AUTOCREATE_TABLES=true

# ── Redis (cache, broker, circuit breaker, blocker counters) ─
REDIS_URL=redis://redis:6379/0

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── LLM (OpenAI) ─────────────────────────────────────────
# SECRET — sourced from AWS Secrets Manager / Vault in prod.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_MAX_DIFF_CHARS=6000
LLM_MAX_CONTENT_HEAD=4500
LLM_MAX_CONTENT_TAIL=1500
LLM_SCORING_MAX_TOKENS=600
LLM_OBLIGATIONS_MAX_TOKENS=1200
LLM_ERROR_LOG_RESPONSE_CHARS=1000

# ── M3 / M4 gating ───────────────────────────────────────
OBLIGATIONS_SCORE_GATE=0.6
LLM_OBLIGATIONS_MAX_CONTENT=6000

# ── Celery resilience ────────────────────────────────────
CELERY_SCORING_MAX_RETRIES=3
CELERY_OBLIGATIONS_MAX_RETRIES=3
CELERY_SCORING_RATE_LIMIT=60/m
CELERY_OBLIGATIONS_RATE_LIMIT=30/m
LLM_CIRCUIT_BREAKER_THRESHOLD=10
LLM_CIRCUIT_BREAKER_WINDOW_SECONDS=60
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# ── Crawl / ingestion ────────────────────────────────────
CRAWL_DEFAULT_RATE_LIMIT_RPS=1.0
CRAWL_DEFAULT_MAX_PAGES=50
CRAWL_DEFAULT_MAX_DEPTH=3
CRAWL_DEFAULT_MAX_PDFS=20
CRAWL_DEFAULT_MAX_XMLS=10
CRAWL_HTTP_TIMEOUT_SECONDS=30
CRAWL_MAX_TEXT_CHARS=500000

# ── AWS S3 artifact storage (leave blank to skip) ─────────
AWS_S3_BUCKET=
AWS_REGION=eu-north-1
# SECRETS — vault-sourced in prod.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Email / IMAP (leave blank to skip) ───────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
# SECRET — vault-sourced in prod.
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# ── Ingestion HTTP (optional) ────────────────────────────
# Comma-separated host suffixes for which ingestion HTTP calls skip TLS verify.
# Example: INGEST_TLS_SKIP_VERIFY_HOST_SUFFIXES=dof.gob.mx
INGEST_TLS_SKIP_VERIFY_HOST_SUFFIXES=
